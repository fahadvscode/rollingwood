# Public Supabase project URL (safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Server-only — set in Vercel Environment Variables, never commit real values
# Prefer service role for production API routes:
SUPABASE_SERVICE_ROLE_KEY=
# Or anon key with insert-only RLS on rollingwood_leads:
SUPABASE_ANON_KEY=
